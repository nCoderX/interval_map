# =============================================================================
# Modern C++ / CMake / vcpkg .gitignore
# =============================================================================

# Build directories (the main thing the user cares about)
build/
build*/
out/
cmake-build-*/
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
cmake_uninstall.cmake
compile_commands.json
CTestTestfile.cmake
Testing/
install_manifest.txt

# vcpkg
vcpkg_installed/
vcpkg-manifest.log

# IDE / Editor
.idea/
.vs/
.vscode/
*.swp
*.swo
*~

# Compiled object files / libraries
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe

# Logs and temporary files
*.log
*.tmp
*.temp

# Keep the old VS ignores below if you still use Visual Studio heavily
# (trimmed down version)

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# Build results (additional VS patterns)
x64/
x86/
ARM/
ARM64/
